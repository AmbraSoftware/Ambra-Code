generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model PlatformSystem {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String       @unique
  description String?
  status      String       @default("ACTIVE")
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(3)
  governments Government[]
  schools     School[]
  sysConfig   SysConfig?

  @@map("platform_systems")
}

model Government {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  taxId     String         @unique
  slug      String         @unique
  systemId  String         @db.Uuid
  planId    String         @db.Uuid
  config    Json?
  createdAt DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt DateTime       @updatedAt @db.Timestamptz(3)
  plan      Plan           @relation(fields: [planId], references: [id])
  system    PlatformSystem @relation(fields: [systemId], references: [id])
  schools   School[]
  users     User[]

  @@map("governments")
}

model Operator {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  taxId              String              @unique
  asaasId            String?             @unique
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)
  asaasToken         String?
  asaasWalletId      String?
  address            String?
  addressNumber      String?
  asaasApiKey        String?
  dataExpirationDate DateTime?           @db.Date
  isDataExpired      Boolean             @default(false)
  mobilePhone        String?
  postalCode         String?
  canteens           Canteen[]
  fiscalItems        FiscalPendingItem[]
  invoices           Invoice[]
  transactions       Transaction[]

  @@map("operators")
}

model WebhookEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String    @unique
  provider    String    @default("ASAAS")
  eventType   String
  payload     Json
  processedAt DateTime? @db.Timestamptz(3)
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)

  @@map("webhook_events")
}

model Plan {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  description     String?
  price           Decimal             @db.Decimal(12, 2)
  discountPercent Decimal             @default(0.00) @db.Decimal(5, 2)
  maxStudents     Int                 @default(100)
  maxCanteens     Int                 @default(1)
  status          PlanStatus          @default(ACTIVE)
  features        Json?
  createdAt       DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @db.Timestamptz(3)
  creditCeiling   Decimal             @default(0.00) @db.Decimal(12, 2)
  feesConfig      Json?
  target          PlanTarget          @default(SCHOOL_SAAS)
  coupons         Coupon[]
  governments     Government[]
  planHistory     SchoolPlanHistory[]
  schools         School[]

  @@index([status])
  @@map("plans")
}

model SchoolPlanHistory {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId  String    @db.Uuid
  planId    String    @db.Uuid
  startedAt DateTime  @default(now()) @db.Timestamptz(3)
  endedAt   DateTime? @db.Timestamptz(3)
  plan      Plan      @relation(fields: [planId], references: [id])
  school    School    @relation(fields: [schoolId], references: [id])

  @@index([schoolId, startedAt])
  @@map("school_plan_histories")
}

model School {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  taxId               String               @unique
  slug                String               @unique
  customDomain        String?              @unique
  status              SchoolStatus         @default(PENDING)
  active              Boolean              @default(true)
  systemId            String               @db.Uuid
  planId              String               @db.Uuid
  governmentId        String?              @db.Uuid
  referredBy          String?
  affiliateCommission Float                @default(0.0)
  config              Json?
  createdAt           DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime             @updatedAt @db.Timestamptz(3)
  asaasCustomerId     String?
  subscriptionId      String?
  address             String?
  addressNumber       String?
  asaasAccountId      String?
  asaasApiKey         String?
  asaasWalletId       String?
  customFeesConfig    Json?
  mobilePhone         String?
  postalCode          String?
  announcements       Announcement[]
  auditLogs           AuditLog[]
  canteens            Canteen[]
  discountRules       DiscountRule[]
  invitations         GuardianInvitation[]
  invoices            Invoice[]
  orders              Order[]
  products            Product[]
  planHistory         SchoolPlanHistory[]
  government          Government?          @relation(fields: [governmentId], references: [id])
  plan                Plan                 @relation(fields: [planId], references: [id])
  system              PlatformSystem       @relation(fields: [systemId], references: [id])
  users               User[]

  @@index([status, slug])
  @@index([governmentId])
  @@map("schools")
}

model Canteen {
  id            String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  type          CanteenType        @default(COMMERCIAL)
  schoolId      String             @db.Uuid
  operatorId    String?            @db.Uuid
  status        String             @default("ACTIVE")
  openingTime   String             @default("07:00")
  closingTime   String             @default("18:00")
  createdAt     DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime           @updatedAt @db.Timestamptz(3)
  deletedAt     DateTime?          @db.Timestamptz(3)
  operator      Operator?          @relation(fields: [operatorId], references: [id])
  school        School             @relation(fields: [schoolId], references: [id])
  inventoryLogs InventoryLog[]
  products      Product[]
  reservations  StockReservation[]
  operators     User[]
  menus         WeeklyMenu[]

  @@index([schoolId, status])
  @@map("canteens")
}

model User {
  id                    String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                  String
  email                 String                @unique
  passwordHash          String
  document              String?
  documentHash          String?
  birthDate             DateTime?             @db.Date
  role                  UserRole?             @default(STUDENT)
  schoolId              String?               @db.Uuid
  governmentId          String?               @db.Uuid
  canteenId             String?               @db.Uuid
  termsAccepted         Boolean               @default(false)
  termsVersion          String?
  lastLoginAt           DateTime?             @db.Timestamptz(3)
  createdAt             DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime              @updatedAt @db.Timestamptz(3)
  deletedAt             DateTime?             @db.Timestamptz(3)
  mustChangePassword    Boolean               @default(false)
  nfcId                 String?               @unique
  avatarUrl             String?
  subscriptionExpiresAt DateTime?             @db.Timestamptz(3)
  subscriptionPlanId    String?               @db.Uuid
  subscriptionStatus    String?
  class                 String?
  roles                 UserRole[]            @default([STUDENT])
  dependentRelations    UserDependency[]      @relation("GuardianToDependent")
  guardianRelations     UserDependency[]      @relation("DependentToGuardian")
  authoredAnnouncements Announcement[]
  auditLogs             AuditLog[]
  restrictedCategories  CategoryRestriction[]
  consentLogs           ConsentLog[]
  favorites             Favorite[]
  receivedInvitations   GuardianInvitation[]  @relation("Receiver")
  sentInvitations       GuardianInvitation[]  @relation("Sender")
  ratings               MenuRating[]
  nutritionalProfile    NutritionalProfile?
  ordersAsBuyer         Order[]               @relation("BuyerOrders")
  ordersAsStudent       Order[]               @relation("StudentOrders")
  restrictedProducts    ProductRestriction[]
  transactions          Transaction[]
  canteen               Canteen?              @relation(fields: [canteenId], references: [id])
  government            Government?           @relation(fields: [governmentId], references: [id])
  school                School?               @relation(fields: [schoolId], references: [id])
  wallet                Wallet?

  @@index([schoolId, role])
  @@index([governmentId])
  @@map("users")
}

model UserDependency {
  guardianId  String @map("A") @db.Uuid
  dependentId String @map("B") @db.Uuid
  guardian    User   @relation("GuardianToDependent", fields: [guardianId], references: [id], onDelete: Cascade)
  dependent   User   @relation("DependentToGuardian", fields: [dependentId], references: [id], onDelete: Cascade)

  @@id([guardianId, dependentId])
  @@map("_UserDependencies")
}

model ConsentLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  action    String
  ipAddress String?
  userAgent String?
  version   String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  user      User     @relation(fields: [userId], references: [id])

  @@map("consent_logs")
}

model AuditKey {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  keyAlias  String   @unique @map("key_alias")
  secret    String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  @@map("audit_keys")
}

model GuardianInvitation {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String           @db.Uuid
  senderId   String           @db.Uuid
  receiverId String           @db.Uuid
  status     InvitationStatus @default(PENDING)
  createdAt  DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime         @updatedAt @db.Timestamptz(3)
  receiver   User             @relation("Receiver", fields: [receiverId], references: [id])
  school     School           @relation(fields: [schoolId], references: [id])
  sender     User             @relation("Sender", fields: [senderId], references: [id])

  @@unique([senderId, receiverId])
  @@index([schoolId])
  @@map("guardian_invitations")
}

model DiscountRule {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String   @db.Uuid
  name       String
  target     String
  type       String
  value      Decimal  @db.Decimal(12, 2)
  conditions Json?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now()) @db.Timestamptz(3)
  school     School   @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("discount_rules")
}

model Wallet {
  id               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String        @unique @db.Uuid
  balance          Decimal       @default(0.00) @db.Decimal(12, 2)
  version          Int           @default(0)
  dailySpendLimit  Decimal       @default(0.00) @db.Decimal(12, 2)
  canPurchaseAlone Boolean       @default(true)
  canRechargeAlone Boolean       @default(true)
  allowedDays      Int[]         @default([1, 2, 3, 4, 5])
  updatedAt        DateTime      @updatedAt @db.Timestamptz(3)
  creditLimit      Decimal       @default(0.00) @db.Decimal(12, 2)
  overdraftLimit   Decimal       @default(0.00) @db.Decimal(10, 2)
  isDebtBlocked    Boolean       @default(false) @map("is_debt_blocked")
  negativeSince    DateTime?     @db.Timestamptz(3)
  dailySpending    DailySpend[]
  transactions     Transaction[]
  user             User          @relation(fields: [userId], references: [id])

  @@map("wallets")
}

model Transaction {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId       String             @db.Uuid
  userId         String?            @db.Uuid
  operatorId     String?            @db.Uuid
  amount         Decimal            @db.Decimal(12, 2)
  grossAmount    Decimal?           @db.Decimal(10, 2)
  platformFee    Decimal            @default(5.00) @db.Decimal(12, 2)
  netAmount      Decimal            @db.Decimal(12, 2)
  runningBalance Decimal            @db.Decimal(12, 2)
  type           TransactionType
  status         TransactionStatus  @default(PENDING)
  description    String?
  providerId     String?
  metadata       Json?
  orderId        String?            @db.Uuid
  auditHash      String?
  offlineId      String?            @unique
  syncedAt       DateTime?          @db.Timestamptz(3)
  createdAt      DateTime           @default(now()) @db.Timestamptz(3)
  fiscalItem     FiscalPendingItem?
  invoice        Invoice?
  operator       Operator?          @relation(fields: [operatorId], references: [id])
  order          Order?             @relation(fields: [orderId], references: [id])
  user           User?              @relation(fields: [userId], references: [id])
  wallet         Wallet             @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt(sort: Desc)])
  @@index([orderId])
  @@map("transactions")
}

model Invoice {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  transactionId String?             @unique @db.Uuid
  schoolId      String              @db.Uuid
  operatorId    String?             @db.Uuid
  externalId    String?
  status        InvoiceStatus       @default(PENDING)
  amount        Decimal             @db.Decimal(12, 2)
  taxBase       Decimal             @db.Decimal(12, 2)
  pdfUrl        String?
  issuedAt      DateTime?           @db.Timestamptz(3)
  createdAt     DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime            @updatedAt @db.Timestamptz(3)
  fiscalItems   FiscalPendingItem[]
  operator      Operator?           @relation(fields: [operatorId], references: [id])
  school        School              @relation(fields: [schoolId], references: [id])
  transaction   Transaction?        @relation(fields: [transactionId], references: [id])

  @@index([schoolId])
  @@map("invoices")
}

model FiscalPendingItem {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operatorId    String      @db.Uuid
  transactionId String      @unique @db.Uuid
  invoiceId     String?     @db.Uuid
  amount        Decimal     @db.Decimal(12, 2)
  status        String      @default("PENDING")
  createdAt     DateTime    @default(now()) @db.Timestamptz(3)
  processedAt   DateTime?   @db.Timestamptz(3)
  invoice       Invoice?    @relation(fields: [invoiceId], references: [id])
  operator      Operator    @relation(fields: [operatorId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  @@index([operatorId, status])
  @@map("fiscal_pending_items")
}

model WeeklyMenu {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  canteenId       String       @db.Uuid
  date            DateTime     @db.Date
  items           Json
  nutritionalInfo Json?
  createdAt       DateTime     @default(now()) @db.Timestamptz(3)
  ratings         MenuRating[]
  canteen         Canteen      @relation(fields: [canteenId], references: [id])

  @@map("weekly_menus")
}

model MenuRating {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  menuId    String     @db.Uuid
  userId    String     @db.Uuid
  stars     Int
  comment   String?
  createdAt DateTime   @default(now()) @db.Timestamptz(3)
  menu      WeeklyMenu @relation(fields: [menuId], references: [id])
  user      User       @relation(fields: [userId], references: [id])

  @@map("menu_ratings")
}

model Product {
  id            String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  price         Decimal              @db.Decimal(12, 2)
  salePrice     Decimal?             @db.Decimal(12, 2)
  stock         Int                  @default(0)
  version       Int                  @default(0)
  category      String
  imageUrl      String?
  isKit         Boolean              @default(false)
  isAvailable   Boolean              @default(true)
  canteenId     String               @db.Uuid
  schoolId      String               @db.Uuid
  createdAt     DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime             @updatedAt @db.Timestamptz(3)
  deletedAt     DateTime?            @db.Timestamptz(3)
  minStockAlert Int                  @default(5)
  cost          Decimal?             @db.Decimal(12, 2)
  type          ProductType          @default(SALE)
  favorites     Favorite[]
  inventoryLogs InventoryLog[]
  partOfKits    KitItem[]            @relation("ComponentToKit")
  kitComponents KitItem[]            @relation("KitToComponent")
  orderItems    OrderItem[]
  restrictions  ProductRestriction[]
  canteen       Canteen              @relation(fields: [canteenId], references: [id])
  school        School               @relation(fields: [schoolId], references: [id])
  reservations  StockReservation[]

  @@index([canteenId])
  @@index([schoolId])
  @@map("products")
}

model KitItem {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kitId       String  @db.Uuid
  componentId String  @db.Uuid
  quantity    Int     @default(1)
  component   Product @relation("ComponentToKit", fields: [componentId], references: [id])
  kit         Product @relation("KitToComponent", fields: [kitId], references: [id])

  @@index([kitId])
  @@map("kit_items")
}

model Order {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderHash    String        @unique
  totalAmount  Decimal       @db.Decimal(12, 2)
  status       OrderStatus   @default(PENDING)
  buyerId      String        @db.Uuid
  studentId    String        @db.Uuid
  schoolId     String        @db.Uuid
  deliveredAt  DateTime?     @db.Timestamptz(3)
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(3)
  scheduledFor DateTime?     @db.Timestamptz(3)
  items        OrderItem[]
  buyer        User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  school       School        @relation(fields: [schoolId], references: [id])
  student      User          @relation("StudentOrders", fields: [studentId], references: [id])
  transactions Transaction[]

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([studentId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String  @db.Uuid
  productId String  @db.Uuid
  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model NutritionalProfile {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @unique @db.Uuid
  allergies        String[]
  dailyCalorieGoal Int?
  preferences      String[]
  aiInsights       Json?
  updatedAt        DateTime @updatedAt @db.Timestamptz(3)
  goals            Json?
  user             User     @relation(fields: [userId], references: [id])

  @@map("nutritional_profiles")
}

model AuditLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId     String   @db.Uuid
  userId       String?  @db.Uuid
  action       String
  entity       String
  entityId     String?
  meta         Json?
  ip           String?
  logHash      String?
  previousHash String?
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  school       School   @relation(fields: [schoolId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])

  @@index([schoolId, createdAt(sort: Desc)])
  @@index([previousHash])
  @@map("audit_logs")
}

model StockReservation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  canteenId String   @db.Uuid
  quantity  Int
  reason    String   @default("CHECKOUT")
  status    String   @default("ACTIVE")
  expiresAt DateTime @db.Timestamptz(3)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  canteen   Canteen  @relation(fields: [canteenId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@index([expiresAt])
  @@map("stock_reservations")
}

model InventoryLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @db.Uuid
  canteenId String   @db.Uuid
  change    Int
  reason    String
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  canteen   Canteen  @relation(fields: [canteenId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@map("inventory_logs")
}

model DailySpend {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  walletId String   @db.Uuid
  date     DateTime @db.Date
  amount   Decimal  @db.Decimal(12, 2)
  wallet   Wallet   @relation(fields: [walletId], references: [id])

  @@unique([walletId, date])
  @@map("daily_spending")
}

model ProductRestriction {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String  @db.Uuid
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("product_restrictions")
}

model CategoryRestriction {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId   String @db.Uuid
  category String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("category_restrictions")
}

model Favorite {
  userId    String  @db.Uuid
  productId String  @db.Uuid
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
  @@map("favorites")
}

model SysConfig {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  platformSystemId String         @unique @db.Uuid
  fiscalConfig     Json?
  updatedAt        DateTime       @updatedAt @db.Timestamptz(3)
  platformSystem   PlatformSystem @relation(fields: [platformSystemId], references: [id])

  @@map("sys_configs")
}

model Announcement {
  id         String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId   String?           @db.Uuid
  title      String
  message    String
  targetRole UserRole
  authorId   String            @db.Uuid
  status     String            @default("SENT")
  createdAt  DateTime          @default(now()) @db.Timestamptz(3)
  scope      AnnouncementScope @default(GLOBAL)
  targetIds  String[]
  author     User              @relation(fields: [authorId], references: [id])
  school     School?           @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@map("announcements")
}

model Coupon {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String         @unique
  type       CouponType
  value      Float
  audience   CouponAudience
  planId     String?        @db.Uuid
  validUntil DateTime       @db.Timestamptz(3)
  maxUses    Int?
  usedCount  Int            @default(0)
  status     CouponStatus   @default(ACTIVE)
  createdAt  DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt  DateTime       @updatedAt @db.Timestamptz(3)
  plan       Plan?          @relation(fields: [planId], references: [id])

  @@index([code, status])
  @@map("coupons")
}

model CashInFee {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  boletoGatewayCost     Float    @default(3.49)
  boletoChargeCustomer  Boolean  @default(true)
  boletoCustomerFixed   Float    @default(4.00)
  boletoCustomerPercent Float    @default(0)
  boletoChargeMerchant  Boolean  @default(false)
  boletoMerchantFixed   Float    @default(0)
  boletoMerchantPercent Float    @default(2.5)
  pixGatewayCost        Float    @default(0.99)
  pixChargeCustomer     Boolean  @default(true)
  pixCustomerFixed      Float    @default(2.00)
  pixCustomerPercent    Float    @default(0)
  pixChargeMerchant     Boolean  @default(true)
  pixMerchantFixed      Float    @default(0)
  pixMerchantPercent    Float    @default(1.5)
  createdAt             DateTime @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime @updatedAt @db.Timestamptz(3)

  @@map("cash_in_fees")
}

