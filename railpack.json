{
  "$schema": "https://railway.app/railpack.schema.json",
  "build": {
    "builder": "nixpacks",
    "nixpacksPlan": {
      "providers": ["node"],
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_22", "npm"]
        },
        "install": {
          "cmds": ["npm ci"]
        },
        "build": {
          "cmds": [
            "npm install prisma@5.21.1 --save-exact",
            "npx prisma generate --schema=apps/backend/prisma/schema.prisma",
            "npm run build -w apps/backend"
          ]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "npx prisma migrate deploy --schema=apps/backend/prisma/schema.prisma && node apps/backend/dist/main.js"
  }
}
